---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Women's Haircut Myeongdong | Korean Women's Hair at CHAHONG ROOM Seoul"
  description="Expert women's haircut in Myeongdong Seoul. Wolf cut, layers, see-through bangs, curtain bangs. Full English service at CHAHONG ROOM. Walk-ins welcome."
>
  <Nav />
  <main class="pt-24" style="background: #F7F4EF;">

    <!-- Hero -->
    <section class="relative overflow-hidden" style="min-height: 85vh; background: #FFFFFF;">
      <div class="absolute right-0 top-0 bottom-0 hidden lg:block" style="width: 50%;">
        <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=900&q=80" alt="Women's haircut Myeongdong Seoul" class="w-full h-full object-cover" loading="eager" />
        <div class="absolute inset-0" style="background: linear-gradient(to right, #FFFFFF 5%, transparent 40%);"></div>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 flex items-center min-h-[85vh] py-20">
        <div class="max-w-lg">
          <p class="mb-4 tracking-widest uppercase text-xs font-medium" style="color: #A88F7B;">Women's Haircut · Styling · Myeongdong</p>
          <h1 class="font-display mb-6" style="font-size: clamp(2.5rem, 6vw, 5rem); color: #3A3838; font-weight: 300; line-height: 1.1;">
            Women's Haircut<br/>
            <em style="color: #A88F7B; font-style: italic;">in Myeongdong</em>
          </h1>
          <div class="mb-6" style="width: 60px; height: 1px; background: #A88F7B;"></div>
          <p class="leading-relaxed mb-8" style="color: #8D8076; font-size: 1rem;">
            Korean women's haircuts are famous worldwide — from the iconic wolf cut to delicate see-through bangs. Our stylists specialize in the trending styles loved by K-drama stars and K-pop idols, adapted to flatter your face shape and lifestyle.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-10">
            <a href="https://wa.me/821047944623" target="_blank" class="btn-gold">💬 Book via WhatsApp</a>
            <a href="/pricing" class="btn-outline">View Pricing</a>
          </div>
          <div class="grid grid-cols-3 gap-3">
            {[
              { num: 'From ₩40,000', label: 'Women\'s Cut' },
              { num: '45–75', label: 'Minutes' },
              { num: '100%', label: 'English' },
            ].map(b => (
              <div class="text-center p-3" style="border: 1px solid #DCCDBD; border-radius: 6px;">
                <p class="font-display text-sm font-semibold" style="color: #A88F7B;">{b.num}</p>
                <p class="text-xs tracking-widest uppercase mt-1" style="color: #8D8076;">{b.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Popular Women's Styles -->
    <section class="py-24 px-6 lg:px-12" style="background: #F7F4EF;">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14">
          <p class="mb-3 tracking-widest uppercase text-xs font-medium" style="color: #A88F7B;">Most Requested</p>
          <h2 class="font-display text-4xl mb-4" style="color: #3A3838; font-weight: 300;">Popular Women's <em style="color: #A88F7B;">Korean Haircuts</em></h2>
          <div class="mx-auto mt-4" style="width: 60px; height: 1px; background: #A88F7B;"></div>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            {
              img: 'https://images.unsplash.com/photo-1560066984-138dadb4c035?w=600&q=80',
              title: 'Wolf Cut (울프컷)',
              tag: '#1 Most Requested',
              desc: 'The defining Korean haircut of the decade. Heavy, shaggy layers at the crown with wispy textured ends. Creates effortless volume and movement that looks great air-dried or styled. Works on all hair lengths and face shapes.',
              price: 'From ₩50,000',
              time: '60–75 min'
            },
            {
              img: 'https://images.unsplash.com/photo-1492106087820-71f1a00d2b11?w=600&q=80',
              title: 'See-Through Bangs (시스루뱅)',
              tag: 'Most Delicate',
              desc: 'Wispy, feather-light bangs that frame the face without overwhelming it. The Korean answer to heavy fringe. Grows out beautifully and complements any face shape. Often added to any cut.',
              price: 'From ₩10,000',
              time: '15–25 min'
            },
            {
              img: 'https://images.unsplash.com/photo-1519699047748-de8e457a634e?w=600&q=80',
              title: 'Curtain Bangs (커튼뱅)',
              tag: 'Timeless Classic',
              desc: 'Center-parted bangs that sweep to either side. Soft, romantic and universally flattering. Creates a face-framing effect that photographs beautifully. One of the most requested bang styles at CHAHONG ROOM.',
              price: 'From ₩10,000',
              time: '20–30 min'
            },
            {
              img: 'https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=600&q=80',
              title: 'Layered Cut',
              desc: 'Classic layers that add movement, reduce weight and enhance your natural texture. Available in face-framing only, through-length layers or shag-style choppy layers. A versatile foundation for any style.',
              price: 'From ₩40,000',
              time: '45–60 min'
            },
            {
              img: 'https://images.unsplash.com/photo-1560066984-138dadb4c035?w=600&q=80',
              title: 'Korean Bob (단발)',
              desc: 'The Korean bob is sleeker and more structured than Western versions. Often features a slight inward curl at the ends (C-curl), a clean jaw-length line and face-framing layers. Chic and polished.',
              price: 'From ₩45,000',
              time: '45–60 min'
            },
            {
              img: 'https://images.unsplash.com/photo-1492106087820-71f1a00d2b11?w=600&q=80',
              title: 'Long Layer Cut',
              desc: 'Subtle layers through long hair that add movement without changing length dramatically. Perfect for those wanting to maintain length while refreshing their style. Often combined with face-framing layers and see-through bangs.',
              price: 'From ₩40,000',
              time: '45–60 min'
            },
          ].map(s => (
            <div class="overflow-hidden" style="border: 1px solid #DCCDBD; border-radius: 8px; background: #FFFFFF;">
              <div style="height: 200px; overflow: hidden; position: relative;">
                <img src={s.img} alt={s.title} class="w-full h-full object-cover" loading="lazy" />
                {s.tag && (
                  <span class="absolute top-3 left-3 text-xs px-2 py-1" style="background: #A88F7B; color: white; border-radius: 4px;">{s.tag}</span>
                )}
              </div>
              <div class="p-5">
                <h3 class="font-display text-lg mb-2" style="color: #3A3838;">{s.title}</h3>
                <p class="text-sm leading-relaxed mb-4" style="color: #8D8076;">{s.desc}</p>
                <div class="flex items-center justify-between pt-3" style="border-top: 1px solid #DCCDBD;">
                  <span class="text-sm font-semibold" style="color: #A88F7B;">{s.price}</span>
                  <span class="text-xs" style="color: #8D8076;">⏱ {s.time}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- What's Included -->
    <section class="py-24 px-6 lg:px-12" style="background: #3A3838;">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-14">
          <p class="mb-3 tracking-widest uppercase text-xs font-medium" style="color: #A88F7B;">Every Appointment Includes</p>
          <h2 class="font-display text-4xl mb-4" style="color: #FFFFFF; font-weight: 300;">What's Included in Your <em style="color: #A88F7B;">Women's Haircut</em></h2>
          <div class="mx-auto mt-4" style="width: 60px; height: 1px; background: #A88F7B;"></div>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {[
            { icon: '🇬🇧', title: 'English Consultation', desc: 'Thorough discussion of your desired style, face shape analysis and reference photo review — all in English.' },
            { icon: '🚿', title: 'Shampoo & Conditioning', desc: 'Professional shampoo with scalp massage and conditioning treatment before your cut.' },
            { icon: '✂️', title: 'Precision Cut', desc: 'Expert cut using Korean techniques. Your stylist checks in with you throughout the service.' },
            { icon: '💨', title: 'Blow Dry & Styling', desc: 'Professional blow dry and styling. We create the finished look shown in your reference photo.' },
            { icon: '📚', title: 'Home Styling Tips', desc: 'We show you how to recreate the look at home — including which products and tools to use.' },
            { icon: '📸', title: 'Reference Photo Matching', desc: 'We study your reference photos carefully and adapt them to your specific hair type and face shape.' },
          ].map(item => (
            <div class="p-5 flex items-start gap-4" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;">
              <span class="text-2xl flex-shrink-0">{item.icon}</span>
              <div>
                <h3 class="font-display text-base mb-2" style="color: #FFFFFF;">{item.title}</h3>
                <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.6);">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-24 px-6 lg:px-12 max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <p class="mb-3 tracking-widest uppercase text-xs font-medium" style="color: #A88F7B;">Transparent Pricing</p>
        <h2 class="font-display text-4xl mb-4" style="color: #3A3838; font-weight: 300;">Women's Haircut <em style="color: #A88F7B;">Pricing</em></h2>
        <p class="text-sm" style="color: #8D8076;">All prices in KRW. Shampoo & blow dry included with all cuts.</p>
      </div>
      <div style="border: 1px solid #DCCDBD; border-radius: 8px; overflow: hidden;">
        {[
          { service: "Women's Haircut", price: 'From ₩40,000', note: 'Shampoo, cut & blow dry' },
          { service: 'Wolf Cut / Shag Cut', price: 'From ₩50,000', note: 'Heavy layers & texture' },
          { service: 'Korean Bob', price: 'From ₩45,000', note: 'Structured bob styling' },
          { service: 'Bang Trim (see-through / curtain)', price: 'From ₩10,000', note: 'Add-on or standalone' },
          { service: 'Haircut + Blow Dry (event)', price: 'From ₩60,000', note: 'Special occasion styling' },
          { service: "Women's Cut + Treatment", price: 'From ₩70,000', note: 'Cut + deep conditioning' },
          { service: "Women's Cut + Color", price: 'From ₩110,000', note: 'Cut + single color' },
        ].map((item, i) => (
          <div class="flex items-center justify-between px-6 py-4" style={`background: ${i % 2 === 0 ? '#FFFFFF' : '#F7F4EF'}; border-bottom: 1px solid #DCCDBD;`}>
            <div>
              <p class="text-sm" style="color: #3A3838;">{item.service}</p>
              <p class="text-xs mt-0.5" style="color: #8D8076;">{item.note}</p>
            </div>
            <span class="text-sm font-semibold ml-4 flex-shrink-0" style="color: #A88F7B;">{item.price}</span>
          </div>
        ))}
      </div>
      <div class="mt-6 p-5 text-center" style="border: 1px solid #DCCDBD; border-radius: 8px;">
        <p class="text-sm mb-4" style="color: #8D8076;">Send your reference photo via WhatsApp for a free style consultation!</p>
        <a href="https://wa.me/821047944623" target="_blank" class="btn-gold">Book via WhatsApp</a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-24 px-6 lg:px-12 max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <p class="mb-3 tracking-widest uppercase text-xs font-medium" style="color: #A88F7B;">FAQ</p>
        <h2 class="font-display text-4xl mb-4" style="color: #3A3838; font-weight: 300;">Women's Haircut <em style="color: #A88F7B;">Questions</em></h2>
        <div class="mx-auto mt-4" style="width: 60px; height: 1px; background: #A88F7B;"></div>
      </div>
      <div class="space-y-4">
        {[
          { q: 'What\'s the most popular women\'s haircut at CHAHONG ROOM?', a: 'The wolf cut is our most requested women\'s haircut by far, followed by layered cuts with see-through or curtain bangs. Many clients combine a wolf cut with a C-curl or wave perm for the iconic Korean textured look.' },
          { q: 'Do you cut all hair textures?', a: 'Yes — we cut all hair textures including straight, wavy, curly and coily. Our stylists understand how different textures behave and will adapt the technique accordingly.' },
          { q: 'How long does a women\'s haircut take?', a: 'Standard cuts take 45–75 minutes including shampoo and blow dry. More complex styles like the wolf cut or heavily layered cuts take 60–75 minutes. Bang trims are 15–25 minutes.' },
          { q: 'Can I add see-through bangs to any haircut?', a: 'Yes — see-through bangs are a popular add-on to any cut. If you already have bangs, we can restyle them into see-through bangs. If you have no bangs, we can create them from your existing hair.' },
          { q: 'What if I\'m not sure what style to choose?', a: 'Tell us your lifestyle, how much time you spend styling daily and bring photos of styles you like AND dislike. Our stylists will make a recommendation based on your face shape, hair texture and preferences — all in English.' },
        ].map(faq => (
          <details style="border: 1px solid #DCCDBD; border-radius: 6px;">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none">
              <span class="text-sm" style="color: #3A3838;">{faq.q}</span>
              <span class="text-lg ml-4 flex-shrink-0" style="color: #A88F7B;">+</span>
            </summary>
            <p class="px-6 pb-5 pt-4 text-sm leading-relaxed" style="color: #8D8076; border-top: 1px solid #DCCDBD;">{faq.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- Related -->
    <section class="py-16 px-6 lg:px-12 max-w-5xl mx-auto" style="border-top: 1px solid #DCCDBD;">
      <p class="mb-6 text-center tracking-widest uppercase text-xs font-medium" style="color: #A88F7B;">Related Services</p>
      <div class="flex flex-wrap gap-3 justify-center">
        {[
          { href: '/haircut-myeongdong', label: '✂️ All Haircuts' },
          { href: '/mens-haircut-myeongdong', label: '✂️ Men\'s Haircut' },
          { href: '/hair-perm-myeongdong', label: '🧪 Add a Perm' },
          { href: '/hair-color-myeongdong', label: '🎨 Add Color' },
          { href: '/blow-dry-styling-myeongdong', label: '💨 Blow Dry & Styling' },
          { href: '/korean-style-haircut-myeongdong', label: '🇰🇷 Korean Style Cut' },
        ].map(l => (
          <a href={l.href} class="btn-outline text-xs">{l.label}</a>
        ))}
      </div>
    </section>

    <Contact />
  </main>
  <Footer />

  <a href="https://wa.me/821047944623" target="_blank"
    class="fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full flex items-center justify-center shadow-xl transition-all"
    style="background: #25D366;" aria-label="WhatsApp">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
</Layout>
