---
import ServiceLayout from '../layouts/ServiceLayout.astro';
---
<ServiceLayout
  title="Event Styling Myeongdong"
  seoTitle="Event Hair Styling Myeongdong | Special Occasion Hair at CHAHONG ROOM"
  metaDesc="Professional event hair styling in Myeongdong Seoul. Party, graduation, photoshoot and special occasion hair. English-friendly at CHAHONG ROOM."
  emoji="🎉"
  category="Styling"
  heroImage="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=1200&q=80"
  intro="Looking stunning for a special occasion? Our event styling service creates glamorous, long-lasting looks perfect for parties, photoshoots, graduations and more."
  pricing={[
    { service: "Event Updo", price: "From ₩70,000" },
    { service: "Event Waves & Curls", price: "From ₩60,000" },
    { service: "Photoshoot Styling", price: "From ₩80,000" },
    { service: "Full Glam Package", price: "From ₩120,000" },
  ]}
  benefits={[
    "Stunning styles for any occasion — party, graduation, photoshoot, date night",
    "Long-lasting hold with professional styling products",
    "Expert at creating Korean-style glamour looks",
    "Reference photos welcome — we'll recreate your dream style",
    "Quick turnaround — most styles completed in 45–60 minutes",
    "Full English consultation to understand your event and vision",
  ]}
  faqs={[
    { q: "Do I need to book in advance for event styling?", a: "We recommend booking 1–2 weeks ahead for special occasions. Same-day bookings are sometimes available." },
