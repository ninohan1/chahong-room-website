    { q: "Can I bring reference photos?", a: "Yes — we love reference photos and will work to match your inspiration as closely as possible." },
    { q: "Do you offer group bookings for events?", a: "Yes! Contact us via WhatsApp for group pricing and scheduling." },
  ]}
  relatedLinks={[
    { href: '/bridal-updo-myeongdong', label: "Bridal Updo" },
    { href: '/blow-dry-styling-myeongdong', label: "Blow Dry & Styling" },
    { href: '/hair-set-myeongdong', label: "Hair Set" },
    { href: '/haircut-myeongdong', label: "Haircut" },
  ]}
>
  <span slot="headline">Event Styling<br/><em class="text-gold">in Myeongdong</em></span>
</ServiceLayout>
