---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="Ombre Hair Color Myeongdong | Gradient Color at CHAHONG ROOM Seoul"
  description="Professional ombre hair color in Myeongdong Seoul. Dark to light gradient, Korean ombre styles. English-friendly service at CHAHONG ROOM."
>
  <Nav />
  <main class="pt-24" style="background: #F7F4EF;">

    <!-- Hero — Gradient, artistic, color-forward -->
    <section class="relative overflow-hidden" style="min-height: 85vh;">
      <div class="absolute inset-0">
        <img src="https://images.unsplash.com/photo-1492106087820-71f1a00d2b11?w=1600&q=80" alt="Ombre hair color Myeongdong Seoul" class="w-full h-full object-cover" loading="eager" />
        <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(58,56,56,0.92) 0%, rgba(58,56,56,0.5) 50%, rgba(58,56,56,0.2) 100%);"></div>
      </div>
      <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-12 flex items-center min-h-[85vh] py-20">
        <div class="max-w-2xl">
          <p class="mb-4 tracking-widest uppercase text-xs font-medium" style="color: #A88F7B;">Ombre Color · Gradient · Myeongdong</p>
          <h1 class="font-display mb-6" style="font-size: clamp(2.5rem, 7vw, 6rem); color: #FFFFFF; font-weight: 300; line-height: 1.05;">
            Ombre Hair Color<br/>
            <em style="color: #A88F7B; font-style: italic;">in Myeongdong</em>
          </h1>
          <div class="mb-6" style="width: 60px; height: 1px; background: #A88F7B;"></div>
          <p class="leading-relaxed mb-8 max-w-xl" style="color: rgba(255,255,255,0.8); font-size: 1rem;">
            A seamless gradient from dark roots to lighter ends — ombre is one of the most beautiful and low-maintenance color techniques available. It grows out naturally without harsh lines, making it perfect for international visitors who want stunning color that stays beautiful for months.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 mb-10">
            <a href="https://wa.me/821047944623" target="_blank" class="btn-gold">💬 Book via WhatsApp</a>
            <a href="/pricing" style="border: 1.5px solid rgba(255,255,255,0.4); color: white; font-weight: 600; padding: 14px 32px; border-radius: 6px; font-size: 14px; text-transform: uppercase; letter-spacing: 0.05em; display: inline-block;">View Pricing</a>
          </div>
          <!-- Gradient swatches -->
          <div class="flex items-center gap-0 mb-2" style="width: 300px; height: 8px; border-radius: 4px; background: linear-gradient(to right, #3A3838, #8D8076, #C4956A, #E8D5B7);"></div>
          <p class="text-xs" style="color: rgba(255,255,255,0.5);">Dark roots → Light ends — the signature ombre gradient</p>
        </div>
      </div>
    </section>

    <!-- Ombre Styles -->
    <section class="py-24 px-6 lg:px-12" style="background: #FFFFFF;">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14">
          <p class="mb-3 tracking-widest uppercase text-xs font-medium" style="color: #A88F7B;">Style Options</p>
          <h2 class="font-display text-4xl mb-4" style="color: #3A3838; font-weight: 300;">Ombre <em style="color: #A88F7B;">Variations</em></h2>
          <div class="mx-auto mt-4" style="width: 60px; height: 1px; background: #A88F7B;"></div>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            {
              title: 'Classic Ombre',
              gradient: 'linear-gradient(to right, #3A3838, #C4956A)',
              desc: 'Dark roots that gradually transition to lighter ends. The most natural-looking gradient — like your hair has been kissed by the sun. Perfect for first-time color clients.',
              maintain: 'Every 4–6 months',
              price: 'From ₩120,000',
              time: '2–3 hrs'
            },
            {
              title: 'Ash Ombre',
              gradient: 'linear-gradient(to right, #3A3838, #B8B8B0)',
              desc: 'Dark roots fading to cool ash or grey ends. The most popular ombre style in Korea right now. Creates a striking, fashion-forward look that\'s particularly stunning on Asian hair.',
              maintain: 'Every 3–5 months',
              price: 'From ₩150,000',
              time: '3–4 hrs'
            },
            {
              title: 'Reverse Ombre',
              gradient: 'linear-gradient(to right, #E8D5B7, #3A3838)',
              desc: 'Light roots that deepen to darker ends — the opposite of classic ombre. A dramatic, editorial look that\'s less common and makes a real statement.',
              maintain: 'Every 4–6 months',
              price: 'From ₩140,000',
              time: '2–3 hrs'
            },
            {
              title: 'Honey Ombre',
              gradient: 'linear-gradient(to right, #8D7355, #E8C87A)',
              desc: 'Warm, golden transition from dark brown to honey blonde. The most flattering ombre for warm skin tones. Creates a sun-kissed, radiant effect that looks natural in any light.',
              maintain: 'Every 4–6 months',
              price: 'From ₩130,000',
              time: '2.5–3.5 hrs'
            },
            {
              title: 'Platinum Ombre',
              gradient: 'linear-gradient(to right, #3A3838, #E8E0D8)',
              desc: 'The boldest ombre — dark roots fading to platinum or white ends. Requires the most bleaching but creates the most dramatic result. Our colorists specialize in achieving this safely on Asian hair.',
              maintain: 'Every 2–3 months',
              price: 'From ₩180,000',
              time: '3–5 hrs'
            },
            {
              title: 'Ombre + Toner',
              gradient: 'linear-gradient(to right, #3A3838, #B8B4A8)',
              desc: 'Ombre followed immediately by a toning treatment to perfect the final shade. Neutralizes any brassiness and achieves exactly the cool, warm or neutral tone you want. Our most popular ombre combo.',
              maintain: 'Every 3–5 months',
              price: 'From ₩160,000',
              time: '3–5 hrs'
            },
          ].map(s => (
            <div class="overflow-hidden" style="border: 1px solid #DCCDBD; border-radius: 8px; background: #F7F4EF;">
              <div class="h-8" style={`background: ${s.gradient};`}></div>
              <div class="p-5">
                <h3 class="font-display text-lg mb-2" style="color: #3A3838;">{s.title}</h3>
                <p class="text-sm leading-relaxed mb-4" style="color: #8D8076;">{s.desc}</p>
                <div class="grid grid-cols-3 gap-2 pt-3 text-xs" style="border-top: 1px solid #DCCDBD;">
                  <div>
                    <p style="color: #8D8076;">Price</p>
                    <p style="color: #A88F7B; font-weight: 600;">{s.price}</p>
                  </div>
                  <div>
                    <p style="color: #8D8076;">Time</p>
                    <p style="color: #3A3838;">{s.time}</p>
                  </div>
                  <div>
                    <p style="color: #8D8076;">Maintenance</p>
                    <p style="color: #3A3838;">{s.maintain}</p>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why Ombre -->
    <section class="py-24 px-6 lg:px-12" style="background: #3A3838;">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-14">
          <p class="mb-3 tracking-widest uppercase text-xs font-medium" style="color: #A88F7B;">Why Choose Ombre?</p>
          <h2 class="font-display text-4xl mb-4" style="color: #FFFFFF; font-weight: 300;">Why Ombre is Perfect for <em style="color: #A88F7B;">International Visitors</em></h2>
          <div class="mx-auto mt-4" style="width: 60px; height: 1px; background: #A88F7B;"></div>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
          {[
            { icon: '✈️', title: 'Grows Out Beautifully', desc: 'No harsh regrowth line. Ombre grows out naturally — you can wait months between touch-ups without it looking untidy.' },
            { icon: '💰', title: 'Low Maintenance', desc: 'Because roots are intentionally darker, you only need touch-ups every 4–6 months. Perfect for those who don\'t live in Korea.' },
            { icon: '✨', title: 'Flattering on All', desc: 'The gradient effect is universally flattering — it adds dimension and movement that suits all face shapes and skin tones.' },
            { icon: '🎨', title: 'Customizable', desc: 'Choose your gradient intensity, starting point and ending shade. Subtle or dramatic — ombre adapts to your preference.' },
          ].map(item => (
            <div class="p-5 text-center" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;">
              <span class="text-3xl block mb-3">{item.icon}</span>
              <h3 class="font-display text-base mb-2" style="color: #FFFFFF;">{item.title}</h3>
              <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.6);">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-24 px-6 lg:px-12 max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <p class="mb-3 tracking-widest uppercase text-xs font-medium" style="color: #A88F7B;">Transparent Pricing</p>
        <h2 class="font-display text-4xl mb-4" style="color: #3A3838; font-weight: 300;">Ombre <em style="color: #A88F7B;">Pricing</em></h2>
        <p class="text-sm" style="color: #8D8076;">All prices in KRW. Final price depends on hair length & gradient depth.</p>
      </div>
      <div style="border: 1px solid #DCCDBD; border-radius: 8px; overflow: hidden;">
        {[
          { service: 'Classic Ombre', price: 'From ₩120,000', time: '2–3 hrs', note: 'Natural gradient' },
          { service: 'Honey / Warm Ombre', price: 'From ₩130,000', time: '2.5–3.5 hrs', note: 'Golden warm tones' },
          { service: 'Reverse Ombre', price: 'From ₩140,000', time: '2–3 hrs', note: 'Light to dark' },
          { service: 'Ash / Cool Ombre', price: 'From ₩150,000', time: '3–4 hrs', note: 'Cool grey/ash ends' },
          { service: 'Ombre + Toner', price: 'From ₩160,000', time: '3–5 hrs', note: 'Most popular combo' },
          { service: 'Platinum Ombre', price: 'From ₩180,000', time: '3–5 hrs', note: 'Dramatic light ends' },
          { service: 'Ombre + Treatment', price: 'Add ₩30,000', time: '+30 min', note: 'Bond protection add-on' },
        ].map((item, i) => (
          <div class="px-6 py-4" style={`background: ${i % 2 === 0 ? '#FFFFFF' : '#F7F4EF'}; border-bottom: 1px solid #DCCDBD;`}>
            <div class="flex items-start justify-between">
              <div>
                <p class="text-sm font-medium" style="color: #3A3838;">{item.service}</p>
                <p class="text-xs mt-0.5" style="color: #8D8076;">{item.note} · {item.time}</p>
              </div>
              <p class="text-sm font-semibold ml-4 flex-shrink-0" style="color: #A88F7B;">{item.price}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-6 p-5 text-center" style="border: 1px solid #DCCDBD; border-radius: 8px;">
        <p class="text-sm mb-4" style="color: #8D8076;">Send your reference photo for an accurate quote!</p>
        <a href="https://wa.me/821047944623" target="_blank" class="btn-gold">Get a Free Quote</a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-24 px-6 lg:px-12 max-w-3xl mx-auto">
      <div class="text-center mb-12">
        <p class="mb-3 tracking-widest uppercase text-xs font-medium" style="color: #A88F7B;">FAQ</p>
        <h2 class="font-display text-4xl mb-4" style="color: #3A3838; font-weight: 300;">Ombre <em style="color: #A88F7B;">Questions</em></h2>
        <div class="mx-auto mt-4" style="width: 60px; height: 1px; background: #A88F7B;"></div>
      </div>
      <div class="space-y-4">
        {[
          { q: 'What\'s the difference between ombre and balayage?', a: 'Ombre is a more defined gradient from dark to light — the transition is more visible and structured. Balayage is a freehand painting technique that creates a softer, more natural sun-kissed effect. Ombre tends to be more dramatic; balayage more subtle.' },
          { q: 'Will ombre work on dark Asian hair?', a: 'Yes — we specialize in ombre on dark Asian hair. The lightening process requires careful technique to avoid brassiness, which is why professional application is so important. We use bond-protecting treatments throughout.' },
          { q: 'Can I get ombre in one session?', a: 'Yes — most ombre styles are achievable in one session of 2–4 hours. Platinum or very light ombre on dark hair may occasionally require two sessions depending on starting hair condition. We\'ll tell you honestly during consultation.' },
          { q: 'How long does ombre last?', a: 'The beauty of ombre is that it grows out naturally — the roots are intentionally darker, so there\'s no obvious regrowth line. Most clients refresh their ombre every 4–6 months. A toner refresh may be needed every 6–8 weeks if you want to maintain a cool tone.' },
          { q: 'Can I add Olaplex to my ombre appointment?', a: 'Yes — we highly recommend adding Olaplex to any ombre appointment. It protects bonds during bleaching and leaves your hair in significantly better condition afterwards. Ask us about adding it when you book.' },
        ].map(faq => (
          <details style="border: 1px solid #DCCDBD; border-radius: 6px;">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none">
              <span class="text-sm" style="color: #3A3838;">{faq.q}</span>
              <span class="text-lg ml-4 flex-shrink-0" style="color: #A88F7B;">+</span>
            </summary>
            <p class="px-6 pb-5 pt-4 text-sm leading-relaxed" style="color: #8D8076; border-top: 1px solid #DCCDBD;">{faq.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- Related -->
    <section class="py-16 px-6 lg:px-12 max-w-5xl mx-auto" style="border-top: 1px solid #DCCDBD;">
      <p class="mb-6 text-center tracking-widest uppercase text-xs font-medium" style="color: #A88F7B;">Related Services</p>
      <div class="flex flex-wrap gap-3 justify-center">
        {[
          { href: '/hair-color-myeongdong', label: '🎨 Hair Color' },
          { href: '/highlights-balayage-myeongdong', label: '🌟 Highlights & Balayage' },
          { href: '/bleaching-myeongdong', label: '⚡ Bleaching' },
          { href: '/hair-toning-myeongdong', label: '🎨 Hair Toning' },
          { href: '/gray-hair-coloring-myeongdong', label: '🩶 Gray Hair Coloring' },
          { href: '/olaplex-treatment-myeongdong', label: '🔬 Olaplex' },
        ].map(l => (
          <a href={l.href} class="btn-outline text-xs">{l.label}</a>
        ))}
      </div>
    </section>

    <Contact />
  </main>
  <Footer />

  <a href="https://wa.me/821047944623" target="_blank"
    class="fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full flex items-center justify-center shadow-xl transition-all"
    style="background: #25D366;" aria-label="WhatsApp">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
</Layout>
