---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---
<Layout
  title="How to Book | CHAHONG ROOM Myeongdong Hair Salon Seoul"
  description="Learn how to book an appointment at CHAHONG ROOM Myeongdong. Easy WhatsApp booking, walk-ins welcome. English-friendly Korean hair salon in Seoul."
>
  <Nav />
  <main class="pt-28 pb-0">

    <section class="py-20 px-6 text-center border-b border-dark-border">
      <p class="section-label mb-4">Booking Made Easy</p>
      <h1 class="font-display text-5xl md:text-6xl font-300 mb-6">
        How to <em class="text-gold">Book</em>
      </h1>
      <span class="gold-line"></span>
      <p class="text-text-muted max-w-lg mx-auto text-sm font-300">No apps, no complicated systems. Just a WhatsApp message and we'll handle the rest.</p>
    </section>

    <section class="py-24 px-6 lg:px-12 max-w-4xl mx-auto">

      <!-- Steps -->
      <div class="space-y-10 mb-20">
        {[
          {
            step: '01',
            title: 'Message Us on WhatsApp',
            desc: 'Send a WhatsApp message to +82 10-4794-4623. Tell us what service you\'re interested in and your preferred date and time. Photos of your desired look are very helpful!'
          },
          {
            step: '02',
            title: 'We Confirm Your Appointment',
            desc: 'Our team will reply (usually within a few hours) to confirm your booking. We\'ll let you know how much time to allow and any preparation tips.'
          },
          {
            step: '03',
            title: 'Visit CHAHONG ROOM',
            desc: 'Come to 5F, 13 Myeong-dong-gil, Jung-gu, Seoul. Just 2 minutes from Myeongdong Station Exit 6. We\'ll greet you warmly and guide you through the whole process in English.'
          },
          {
            step: '04',
            title: 'Enjoy Your Transformation',
            desc: 'Relax while our expert stylists work their magic. We\'ll check in throughout to make sure you\'re happy. You\'ll leave with your dream hair and clear aftercare advice.'
          },
        ].map(s => (
          <div class="flex gap-8 items-start group">
            <span class="font-mono text-4xl text-gold/20 group-hover:text-gold/50 transition-colors flex-shrink-0">{s.step}</span>
            <div class="border-l border-dark-border pl-8 group-hover:border-gold transition-colors">
              <h3 class="font-display text-xl font-400 mb-3">{s.title}</h3>
              <p class="text-text-muted text-sm font-300 leading-relaxed">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Walk-in info -->
      <div class="border border-dark-border p-8 mb-10">
        <p class="section-label mb-3">Walk-ins Welcome</p>
        <p class="text-text-muted text-sm font-300 leading-relaxed mb-4">
          No appointment? No problem — we welcome walk-in customers for haircuts during all operating hours. For color, perm, and scalp services, we recommend booking ahead to avoid waiting.
        </p>
        <p class="text-white text-sm font-500">📍 5F, 13 Myeong-dong-gil, Jung-gu, Seoul</p>
        <p class="text-text-muted text-sm font-300">🕙 Open every day: 10:00 AM – 7:00 PM</p>
        <p class="text-text-muted text-sm font-300">🚇 2 min from Myeongdong Station Exit 6</p>
      </div>

      <div class="text-center">
        <a href="https://wa.me/821047944623" target="_blank" class="btn-gold mr-4">Book on WhatsApp Now</a>
        <a href="/contact-us" class="btn-outline">Contact Us</a>
      </div>

    </section>

  </main>
  <Footer />

  <a href="https://wa.me/821047944623" target="_blank" class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-xl hover:scale-110 transition-all" aria-label="WhatsApp">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
</Layout>
