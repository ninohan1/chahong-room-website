---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('treatments', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.data.slug ?? post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const seoTitle = post.data.seoTitle ?? post.data.title;
const metaDesc = post.data.metaDescription ?? post.data.description;

const catLabel: Record<string,string> = {
  haircut: '✂️ Haircut & Styling', coloring: '🎨 Hair Coloring',
  'scalp-care': '💆 Scalp & Hair Care', perm: '🧪 Perm & Texture',
  foreigner: '🌍 Foreigner Tips', seo: '⭐ Seoul Tips',
};
---
<Layout title={seoTitle} description={metaDesc}>
  <Nav />
  <main class="pt-28 pb-20">

    <!-- Hero -->
    <section class="relative">
      {post.data.featuredImage && (
        <div class="w-full h-60 md:h-80 overflow-hidden relative">
          <img src={post.data.featuredImage} alt={post.data.title} class="w-full h-full object-cover opacity-40"/>
          <div class="absolute inset-0 bg-gradient-to-t from-dark-bg to-transparent"></div>
        </div>
      )}
      <div class={`px-6 lg:px-12 max-w-3xl mx-auto ${post.data.featuredImage ? 'relative -mt-16' : 'pt-12'}`}>
        <span class="section-label mb-3">{catLabel[post.data.category]}</span>
        <h1 class="font-display text-3xl md:text-5xl font-300 leading-tight mb-4">{post.data.title}</h1>
        <div class="flex items-center gap-4 text-text-muted text-xs mb-10">
          <time>{post.data.pubDate.toLocaleDateString('en-GB', { day:'2-digit', month:'long', year:'numeric' })}</time>
          <span>·</span>
          <a href="/treatments" class="hover:text-gold transition-colors">← All Posts</a>
        </div>
      </div>
    </section>

    <!-- Content -->
    <article class="px-6 lg:px-12 max-w-3xl mx-auto prose-custom">
      <Content />
    </article>

    <!-- CTA -->
    <div class="text-center mt-16 px-6">
      <p class="text-text-muted text-sm mb-5 font-300">Ready to book this treatment?</p>
      <a href="https://wa.me/821047944623" target="_blank" class="btn-gold mr-4">Book via WhatsApp</a>
      <a href="/treatments" class="btn-outline">More Articles</a>
    </div>
  </main>
  <Footer />

  <a href="https://wa.me/821047944623" target="_blank" class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-xl hover:scale-110 transition-all" aria-label="WhatsApp">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
</Layout>

<style is:global>
  .prose-custom h2 { font-family:'Cormorant Garamond',serif; font-size:1.6rem; font-weight:400; color:#fff; margin:2rem 0 0.75rem; }
  .prose-custom h3 { font-family:'Cormorant Garamond',serif; font-size:1.2rem; color:#C9A96E; margin:1.5rem 0 0.5rem; }
  .prose-custom p { color:#777; line-height:1.9; margin-bottom:1.2rem; font-weight:300; font-size:0.9rem; }
  .prose-custom ul,.prose-custom ol { color:#777; padding-left:1.4rem; margin-bottom:1.2rem; }
  .prose-custom li { margin-bottom:0.4rem; line-height:1.7; font-size:0.875rem; font-weight:300; }
  .prose-custom strong { color:#fff; font-weight:500; }
  .prose-custom table { width:100%; border-collapse:collapse; margin:1.5rem 0; font-size:0.8rem; }
  .prose-custom th { background:#0F0F0F; color:#C9A96E; padding:9px 13px; text-align:left; border:1px solid #1A1A1A; font-weight:500; }
  .prose-custom td { padding:9px 13px; color:#777; border:1px solid #1A1A1A; }
  .prose-custom a { color:#C9A96E; text-decoration:none; }
  .prose-custom a:hover { color:#E8D5B0; }
  .prose-custom blockquote { border-left:2px solid #C9A96E; padding-left:1rem; color:#aaa; font-style:italic; margin:1.5rem 0; }
  .prose-custom hr { border:none; border-top:1px solid #1A1A1A; margin:2rem 0; }
</style>
