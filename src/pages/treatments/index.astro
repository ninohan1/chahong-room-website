---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('treatments', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const catLabel: Record<string,string> = {
  haircut: '✂️ Haircut & Styling', coloring: '🎨 Hair Coloring',
  'scalp-care': '💆 Scalp & Hair Care', perm: '🧪 Perm & Texture',
  foreigner: '🌍 Foreigner Tips', seo: '⭐ Seoul Tips',
};

const categories = [
  { value: 'all', label: '✨ All Posts' },
  { value: 'haircut', label: '✂️ Haircut' },
  { value: 'coloring', label: '🎨 Coloring' },
  { value: 'scalp-care', label: '💆 Scalp Care' },
  { value: 'perm', label: '🧪 Perm' },
  { value: 'foreigner', label: '🌍 Foreigner Tips' },
];
---
<Layout
  title="Hair Tips & Treatment Guide | CHAHONG ROOM Myeongdong Blog"
  description="Expert Korean hair care tips, treatment guides and salon advice from CHAHONG ROOM Myeongdong. Browse by category: haircut, perm, coloring, scalp care."
>
  <Nav />
  <main class="pt-28 pb-20">

    <section class="text-center px-6 mb-14">
      <p class="section-label mb-4">Expert Advice</p>
      <h1 class="font-display text-4xl md:text-6xl font-300 mb-4">
        Treatments &amp; <em class="text-gold">Tips</em>
      </h1>
      <span class="gold-line"></span>
      <p class="text-text-muted max-w-md mx-auto text-sm font-300">Korean hair care advice, treatment guides, and beauty tips from our expert stylists.</p>
    </section>

    <!-- Category Filter -->
    <section class="px-6 lg:px-12 max-w-7xl mx-auto mb-12">
      <div class="flex flex-wrap gap-3 justify-center">
        {categories.map(cat => (
          <button data-filter={cat.value} class={`filter-btn px-4 py-2 text-[0.68rem] tracking-widest uppercase border transition-all ${cat.value === 'all' ? 'border-gold text-gold' : 'border-dark-border text-text-muted hover:border-gold hover:text-gold'}`}>
            {cat.label}
          </button>
        ))}
      </div>
    </section>

    <!-- Grid -->
    <section class="px-6 lg:px-12 max-w-7xl mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-7" id="posts-grid">
        {allPosts.map(post => (
          <article data-category={post.data.category} class="post-card border border-dark-border hover:border-gold transition-all duration-300 group overflow-hidden">
            <div class="aspect-video bg-dark-card flex items-center justify-center overflow-hidden">
              {post.data.featuredImage
                ? <img src={post.data.featuredImage} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy"/>
                : <span class="text-5xl opacity-15">{post.data.category === 'haircut' ? '✂️' : post.data.category === 'coloring' ? '🎨' : post.data.category === 'scalp-care' ? '💆' : post.data.category === 'perm' ? '🧪' : '🌍'}</span>
              }
            </div>
            <div class="p-6">
              <span class="section-label mb-3">{catLabel[post.data.category]}</span>
              <h2 class="font-display text-base font-400 mb-3 group-hover:text-gold transition-colors leading-snug">{post.data.title}</h2>
              <p class="text-text-muted text-xs font-300 leading-relaxed mb-5 line-clamp-2">{post.data.description}</p>
              <div class="flex items-center justify-between">
                <time class="font-mono text-[0.6rem] text-text-muted">{post.data.pubDate.toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' })}</time>
                <a href={`/treatments/${post.data.slug ?? post.slug}`} class="text-gold text-[0.68rem] tracking-widest uppercase hover:text-gold-light transition-colors">Read →</a>
              </div>
            </div>
          </article>
        ))}
      </div>
      <div id="no-posts" class="hidden text-center py-20 text-text-muted text-sm">No posts in this category yet.</div>
    </section>

    <div class="text-center mt-16 px-6">
      <a href="https://wa.me/821047944623" target="_blank" class="btn-gold">Book a Treatment</a>
    </div>
  </main>
  <Footer />

  <a href="https://wa.me/821047944623" target="_blank" class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-xl hover:scale-110 transition-all" aria-label="WhatsApp">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
</Layout>

<style>
  .line-clamp-2 { display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
</style>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.post-card');
  const noRes = document.getElementById('no-posts');

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const f = btn.dataset.filter ?? 'all';
      btns.forEach(b => { b.classList.remove('border-gold','text-gold'); b.classList.add('border-dark-border','text-text-muted'); });
      btn.classList.add('border-gold','text-gold');
      btn.classList.remove('border-dark-border','text-text-muted');
      let v = 0;
      cards.forEach(c => { const show = f === 'all' || c.dataset.category === f; c.style.display = show ? '' : 'none'; if (show) v++; });
      noRes?.classList.toggle('hidden', v > 0);
    });
  });
</script>
