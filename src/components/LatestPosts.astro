---
import { getCollection } from 'astro:content';

const posts = (await getCollection('treatments', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const catLabel: Record<string,string> = {
  haircut: '✂️ Haircut', coloring: '🎨 Coloring',
  'scalp-care': '💆 Scalp Care', perm: '🧪 Perm',
  foreigner: '🌍 Foreigner Tips', seo: '⭐ Seoul Tips',
};
---

{posts.length > 0 && (
<section class="py-28 px-6 lg:px-12 max-w-7xl mx-auto">
  <div class="text-center mb-14">
    <p class="section-label mb-4">Tips & Insights</p>
    <h2 class="font-display text-4xl md:text-5xl font-300">
      Latest <em class="text-gold">Treatment</em> Tips
    </h2>
    <span class="gold-line"></span>
    <p class="text-text-muted max-w-md mx-auto text-sm font-300">Expert advice on Korean hair care, beauty trends, and our signature treatments.</p>
  </div>

  <div class="grid md:grid-cols-3 gap-7">
    {posts.map(post => (
      <article class="border border-dark-border hover:border-gold transition-all duration-300 group overflow-hidden">
        <div class="aspect-video bg-dark-card flex items-center justify-center overflow-hidden">
          {post.data.featuredImage
            ? <img src={post.data.featuredImage} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy"/>
            : <span class="text-5xl opacity-20">{post.data.category === 'haircut' ? '✂️' : post.data.category === 'coloring' ? '🎨' : post.data.category === 'scalp-care' ? '💆' : post.data.category === 'perm' ? '🧪' : '🌍'}</span>
          }
        </div>
        <div class="p-6">
          <span class="section-label mb-3">{catLabel[post.data.category] ?? post.data.category}</span>
          <h3 class="font-display text-base font-400 mb-3 group-hover:text-gold transition-colors leading-snug">{post.data.title}</h3>
          <p class="text-text-muted text-xs font-300 leading-relaxed mb-5 line-clamp-2">{post.data.description}</p>
          <a href={`/treatments/${post.data.slug ?? post.slug}`} class="text-gold text-xs tracking-widest uppercase hover:text-gold-light transition-colors">Read More →</a>
        </div>
      </article>
    ))}
  </div>

  <div class="text-center mt-12">
    <a href="/treatments" class="btn-outline">View All Articles</a>
  </div>
</section>
)}

<style>
  .line-clamp-2 { display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
</style>
