---
import { getCollection } from 'astro:content';
const posts = (await getCollection('treatments', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
const catLabel: Record<string,string> = {
  haircut: '✂️ Haircut', coloring: '🎨 Coloring',
  'scalp-care': '💆 Scalp Care', perm: '🧪 Perm',
  foreigner: '🌍 Foreigner Tips', seo: '⭐ Seoul Tips',
};
const catImage: Record<string,string> = {
  haircut: 'https://images.unsplash.com/photo-1560066984-138dadb4c035?w=600&q=80',
  coloring: 'https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=600&q=80',
  perm: 'https://images.unsplash.com/photo-1492106087820-71f1a00d2b11?w=600&q=80',
  'scalp-care': 'https://images.unsplash.com/photo-1470259078422-826894b933aa?w=600&q=80',
  foreigner: 'https://images.unsplash.com/photo-1519699047748-de8e457a634e?w=600&q=80',
  seo: 'https://images.unsplash.com/photo-1560066984-138dadb4c035?w=600&q=80',
};
---
{posts.length > 0 && (
<section class="py-28 px-6 lg:px-12 max-w-7xl mx-auto">
  <div class="text-center mb-14">
    <p class="mb-4 tracking-widest uppercase text-xs font-medium" style="color: #A88F7B;">Tips & Insights</p>
    <h2 class="font-display text-4xl md:text-5xl mb-4" style="color: #3A3838; font-weight: 300;">
      Latest <em style="color: #A88F7B;">Treatment</em> Tips
    </h2>
    <div class="mx-auto my-6" style="width: 60px; height: 1px; background: #A88F7B;"></div>
    <p class="max-w-md mx-auto text-sm" style="color: #8D8076;">Expert advice on Korean hair care, beauty trends, and our signature treatments.</p>
  </div>
  <div class="grid md:grid-cols-3 gap-7">
    {posts.map(post => (
      <article class="group overflow-hidden" style="border: 1px solid #DCCDBD; border-radius: 8px; background: #FFFFFF;">
        <div class="overflow-hidden" style="height: 200px;">
          <img
            src={post.data.featuredImage ?? catImage[post.data.category] ?? 'https://images.unsplash.com/photo-1560066984-138dadb4c035?w=600&q=80'}
            alt={post.data.title}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading="lazy"
          />
        </div>
        <div class="p-6">
          <span class="mb-3 block tracking-widest uppercase text-xs font-medium" style="color: #A88F7B;">{catLabel[post.data.category] ?? post.data.category}</span>
          <h3 class="font-display text-base mb-3 leading-snug" style="color: #3A3838;">{post.data.title}</h3>
          <p class="text-xs leading-relaxed mb-5 line-clamp-2" style="color: #8D8076;">{post.data.description}</p>
          <a href={`/treatments/${post.data.slug ?? post.slug}`} class="text-xs tracking-widest uppercase transition-colors" style="color: #A88F7B;">Read More →</a>
        </div>
      </article>
    ))}
  </div>
  <div class="text-center mt-12">
    <a href="/treatments" class="btn-outline">View All Articles</a>
  </div>
</section>
)}
<style>
  .line-clamp-2 { display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
</style>
