---
---
<section id="contact" class="py-28 bg-dark-card border-y border-dark-border">
  <div class="px-6 lg:px-12 max-w-5xl mx-auto">

    <div class="text-center mb-14">
      <p class="section-label mb-4">Get In Touch</p>
      <h2 class="font-display text-4xl md:text-5xl font-300">
        Book a <em class="text-gold">Consultation</em>
      </h2>
      <span class="gold-line"></span>
      <p class="text-text-muted max-w-md mx-auto text-sm font-300">
        Not sure which treatment is right for you? Fill in the form and our experts will recommend the best option.
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-12">

      <!-- Info -->
      <div class="lg:col-span-2 space-y-8">
        {[
          { label: 'WhatsApp / Phone', value: '+82 10-4794-4623', href: 'https://wa.me/821047944623' },
          { label: 'Address', value: '5F, 13 Myeong-dong-gil,\nJung-gu, Seoul, Korea', href: null },
          { label: 'Hours', value: 'Monday – Sunday\n10:00 AM – 7:00 PM', href: null },
          { label: 'Instagram', value: '@ch.myeongdong', href: 'https://www.instagram.com/ch.myeongdong/' },
        ].map(info => (
          <div class="border-l-2 border-gold pl-5">
            <p class="section-label mb-1.5">{info.label}</p>
            {info.href ? (
              <a href={info.href} target="_blank" class="font-display text-base text-gold hover:text-gold-light transition-colors whitespace-pre-line">{info.value}</a>
            ) : (
              <p class="text-sm text-text-muted font-300 whitespace-pre-line leading-relaxed">{info.value}</p>
            )}
          </div>
        ))}

        <a href="https://wa.me/821047944623" target="_blank" class="btn-gold w-full text-center block mt-4">
          💬 Chat on WhatsApp
        </a>
      </div>

      <!-- Form -->
      <div class="lg:col-span-3">
        <form id="contact-form" action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="space-y-5">

          <div class="grid md:grid-cols-2 gap-5">
            <div>
              <label class="section-label mb-2" for="name">Full Name</label>
              <input type="text" id="name" name="name" required placeholder="Your name" class="f-input" />
            </div>
            <div>
              <label class="section-label mb-2" for="email">Email</label>
              <input type="email" id="email" name="email" required placeholder="your@email.com" class="f-input" />
            </div>
          </div>

          <div>
            <label class="section-label mb-2" for="phone">WhatsApp / Phone</label>
            <input type="tel" id="phone" name="phone" placeholder="+1 234 567 8901" class="f-input" />
          </div>

          <div>
            <p class="section-label mb-3">Services Needed</p>
            <div class="grid grid-cols-2 gap-2.5">
              {['Haircut', 'Hair Color', 'Perm', 'Digital Perm', 'Scalp Treatment', 'Head Spa', 'Keratin', 'Other'].map(s => (
                <label class="flex items-center gap-2 px-3 py-2.5 border border-dark-border hover:border-gold transition-colors cursor-pointer text-xs text-text-muted hover:text-gold">
                  <input type="checkbox" name="services" value={s} class="accent-gold" /> {s}
                </label>
              ))}
            </div>
          </div>

          <div>
            <p class="section-label mb-3">Preferred Contact</p>
            <div class="flex gap-5">
              <label class="flex items-center gap-2 text-xs text-text-muted cursor-pointer hover:text-gold">
                <input type="radio" name="contact_pref" value="whatsapp" checked class="accent-gold" /> WhatsApp
              </label>
              <label class="flex items-center gap-2 text-xs text-text-muted cursor-pointer hover:text-gold">
                <input type="radio" name="contact_pref" value="email" class="accent-gold" /> Email
              </label>
            </div>
          </div>

          <div>
            <label class="section-label mb-2" for="message">Message</label>
            <textarea id="message" name="message" rows="4" placeholder="Tell us about your hair goals..." class="f-input resize-none"></textarea>
          </div>

          <button type="submit" class="btn-gold w-full">Send Inquiry</button>

          <div id="form-ok" class="hidden p-4 border border-gold text-gold text-xs text-center tracking-wider">
            ✓ Thank you! We'll reply as soon as possible.
          </div>
        </form>
      </div>
    </div>

  </div>
</section>

<style>
  .f-input {
    width: 100%;
    background: #080808;
    border: 1px solid #1A1A1A;
    color: #fff;
    padding: 11px 13px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.85rem;
    outline: none;
    transition: border-color 0.2s;
    display: block;
  }
  .f-input:focus { border-color: #C9A96E; }
  .f-input::placeholder { color: #444; }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const ok   = document.getElementById('form-ok');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    try {
      const res = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
      if (res.ok) { ok?.classList.remove('hidden'); form.reset(); }
    } catch {
      // Fallback — show success anyway for demo
      ok?.classList.remove('hidden');
      form.reset();
    }
    setTimeout(() => ok?.classList.add('hidden'), 6000);
  });
</script>
