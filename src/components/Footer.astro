---
const services = [
  { href: '/haircut-myeongdong', label: 'Haircut & Styling' },
  { href: '/hair-color-myeongdong', label: 'Hair Coloring' },
  { href: '/hair-perm-myeongdong', label: 'Perm & Texture' },
  { href: '/digital-perm-myeongdong', label: 'Digital Perm' },
  { href: '/scalp-treatment-myeongdong', label: 'Scalp Treatment' },
  { href: '/keratin-treatment-myeongdong', label: 'Keratin Treatment' },
  { href: '/hair-straightening-myeongdong', label: 'Hair Straightening' },
  { href: '/bridal-hair-myeongdong', label: 'Bridal Hair' },
];
const pages = [
  { href: '/', label: 'Home' },
  { href: '/about-us', label: 'About Us' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/how-to-book', label: 'How to Book' },
  { href: '/treatments', label: 'Blog & Tips' },
  { href: '/contact-us', label: 'Contact' },
  { href: '/best-hair-salon-myeongdong', label: 'Best Salon Myeongdong' },
  { href: '/foreigner-friendly-hair-salon-seoul', label: 'Foreigner Friendly' },
];
---

<footer class="border-t border-dark-border bg-dark-bg">

  <!-- CTA Band -->
  <div class="border-b border-dark-border py-14 px-6 text-center">
    <p class="section-label mb-4">Ready to Begin?</p>
    <h2 class="font-display text-3xl md:text-4xl font-300 mb-6">
      Book Your Appointment <em class="text-gold">Today</em>
    </h2>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="https://wa.me/821047944623" target="_blank" class="btn-gold">Book via WhatsApp</a>
      <a href="tel:+821047944623" class="btn-outline">+82 10-4794-4623</a>
    </div>
  </div>

  <!-- Footer Grid -->
  <div class="py-16 px-6 lg:px-12 max-w-7xl mx-auto grid md:grid-cols-4 gap-10">

    <!-- Brand -->
    <div class="md:col-span-1">
      <div class="flex items-center gap-2.5 mb-4">
        <svg width="32" height="32" viewBox="0 0 38 38" fill="none">
          <rect width="38" height="38" fill="#C9A96E" rx="2"/>
          <text x="50%" y="55%" dominant-baseline="middle" text-anchor="middle"
            font-family="serif" font-size="16" font-weight="600" fill="#080808">CR</text>
        </svg>
        <div>
          <p class="font-display text-sm tracking-wider">CHAHONG ROOM</p>
          <p class="font-mono text-[0.5rem] tracking-widest text-gold">MYEONGDONG · SEOUL</p>
        </div>
      </div>
      <p class="text-text-muted text-xs font-300 leading-relaxed mb-5">
        Premium K-beauty hair salon in the heart of Myeongdong. Expert stylists, English service, and authentic Korean beauty for international visitors.
      </p>
      <a href="https://www.instagram.com/ch.myeongdong/" target="_blank" class="flex items-center gap-2 text-text-muted text-xs hover:text-gold transition-colors">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        @ch.myeongdong
      </a>
    </div>

    <!-- Services -->
    <div>
      <p class="section-label mb-5">Services</p>
      <nav class="space-y-2.5">
        {services.map(l => (
          <a href={l.href} class="block text-text-muted text-xs hover:text-gold transition-colors font-300">{l.label}</a>
        ))}
      </nav>
    </div>

    <!-- Pages -->
    <div>
      <p class="section-label mb-5">Quick Links</p>
      <nav class="space-y-2.5">
        {pages.map(l => (
          <a href={l.href} class="block text-text-muted text-xs hover:text-gold transition-colors font-300">{l.label}</a>
        ))}
      </nav>
    </div>

    <!-- Contact -->
    <div>
      <p class="section-label mb-5">Contact</p>
      <div class="space-y-3 text-xs text-text-muted font-300">
        <p>5F, 13 Myeong-dong-gil,<br/>Jung-gu, Seoul, Korea</p>
        <a href="https://wa.me/821047944623" target="_blank" class="block hover:text-gold transition-colors">WhatsApp: +82 10-4794-4623</a>
        <a href="tel:+821047944623" class="block hover:text-gold transition-colors">Call: +82 10-4794-4623</a>
        <p>Mon–Sun: 10:00 AM – 7:00 PM</p>
      </div>
    </div>

  </div>

  <!-- Bottom -->
  <div class="border-t border-dark-border py-6 px-6 lg:px-12 flex flex-col sm:flex-row items-center justify-between gap-3">
    <p class="text-text-muted text-[0.65rem] font-300">© 2026 CHAHONG ROOM Myeongdong Hair Salon. All Rights Reserved.</p>
    <p class="text-text-muted text-[0.65rem] font-300">chahongroommyeongdonghairsalon.com</p>
  </div>
</footer>
