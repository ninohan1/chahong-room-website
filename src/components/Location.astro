<section id="location" class="py-28 px-6 lg:px-12 max-w-7xl mx-auto">
  <div class="text-center mb-14">
    <p class="section-label mb-4">Find Us</p>
    <h2 class="font-display text-4xl md:text-5xl font-300">
      Our <em class="text-gold">Location</em>
    </h2>
    <span class="gold-line"></span>
  </div>

  <div class="grid lg:grid-cols-2 gap-10 items-start">
    <div class="border border-dark-border overflow-hidden h-[400px] lg:h-[500px]">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3162.6267959032375!2d126.98040457568244!3d37.563855672039224!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x357ca30066d1bb4b%3A0x9babd32d06d79fcb!2sChaHong+Room+Myeongdong!5e0!3m2!1sen!2skr!4v1700000000000"
        width="100%" height="100%" style="border:0; filter: grayscale(100%) invert(88%) contrast(85%);"
        allowfullscreen loading="lazy" title="CHAHONG ROOM Location"
      ></iframe>
    </div>

    <div class="space-y-7">
      <div class="border-l-2 border-gold pl-5">
        <p class="section-label mb-2">Address</p>
        <p class="font-display text-xl mb-1">CHAHONG ROOM</p>
        <p class="text-text-muted text-sm font-300">5F, 13 Myeong-dong-gil, Jung-gu, Seoul, Korea</p>
      </div>
      <div class="border-l-2 border-dark-border pl-5">
        <p class="section-label mb-2">Hours</p>
        <p class="text-white text-sm font-500">Monday – Sunday</p>
        <p class="text-text-muted text-sm font-300">10:00 AM – 7:00 PM</p>
      </div>
      <div class="border-l-2 border-dark-border pl-5">
        <p class="section-label mb-3">🚇 Getting Here</p>
        <div class="space-y-3">
          <div>
            <p class="text-white text-xs font-500 mb-1">Exit 6 — Recommended</p>
            <p class="text-text-muted text-xs font-300 leading-relaxed">Walk straight toward the main shopping street. 2–3 minutes on foot.</p>
          </div>
          <div>
            <p class="text-white text-xs font-500 mb-1">Exit 8 — Elevator Access</p>
            <p class="text-text-muted text-xs font-300 leading-relaxed">Suitable for guests with luggage or mobility needs.</p>
          </div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-3 pt-2">
        <a href="https://wa.me/821047944623" target="_blank" class="btn-gold text-center text-[0.68rem]">WhatsApp Us</a>
        <a href="tel:+821047944623" class="btn-outline text-center text-[0.68rem]">Call Now</a>
      </div>
    </div>
  </div>
</section>
