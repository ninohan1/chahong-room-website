---
const team = [
  { name: 'Myunghoon Kim', role: 'Director' },
  { name: 'Ruah Lee', role: 'Director' },
  { name: 'Seungmi Hong', role: 'Director' },
  { name: 'Seungyeon Oh', role: 'Designer' },
  { name: 'Subin Park', role: 'Designer' },
  { name: 'Juyoung Kim', role: 'Designer' },
  { name: 'Taerin Lee', role: 'Designer' },
  { name: 'Heejae Kim', role: 'Designer' },
];
const initials = (n: string) => n.split(' ').map(w => w[0]).join('');
---
<section id="team" class="py-28 px-6 lg:px-12 max-w-7xl mx-auto">
  <div class="text-center mb-14">
    <p class="section-label mb-4">The Professionals</p>
    <h2 class="font-display text-4xl md:text-5xl font-300">
      Our <em class="text-gold">Expert</em> Team
    </h2>
    <span class="gold-line"></span>
    <p class="text-text-muted max-w-md mx-auto text-sm font-300">
      Trained to deliver polished, personalized results reflecting the latest Korean trends while enhancing your unique features.
    </p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
    {team.map((m) => (
      <div class="text-center group">
        <div class="mx-auto mb-4 aspect-square max-w-[180px] border border-dark-border group-hover:border-gold transition-all duration-300 overflow-hidden relative bg-dark-card flex flex-col items-center justify-center">
          <!-- Gold circle with initials -->
          <div class="w-20 h-20 rounded-full border-2 border-gold/40 flex items-center justify-center mb-3 group-hover:border-gold transition-colors">
            <span class="font-display text-2xl text-gold/60 group-hover:text-gold transition-colors">{initials(m.name)}</span>
          </div>
          <!-- Scissors icon -->
          <span class="text-gold/20 group-hover:text-gold/40 transition-colors text-lg">✂️</span>
          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-gold/5 opacity-0 group-hover:opacity-100 transition-opacity flex items-end justify-center pb-4">
            <a href="https://wa.me/821047944623" target="_blank" class="text-[0.6rem] tracking-widest uppercase text-gold border border-gold px-3 py-1.5 hover:bg-gold hover:text-dark-bg transition-colors">
              Book Now
            </a>
          </div>
        </div>
        <p class="section-label mb-1">{m.role}</p>
        <h3 class="font-display text-sm font-600 group-hover:text-gold transition-colors">{m.name}</h3>
      </div>
    ))}
  </div>

  <div class="text-center mt-12">
    <p class="text-text-muted text-xs font-300 mb-5">Ready to meet your stylist?</p>
    <a href="https://wa.me/821047944623" target="_blank" class="btn-gold">Book with a Stylist</a>
  </div>
</section>
