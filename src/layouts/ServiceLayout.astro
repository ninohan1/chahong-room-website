---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Contact from '../../components/Contact.astro';
import Location from '../../components/Location.astro';
import Footer from '../../components/Footer.astro';

interface Props {
  title: string;
  seoTitle: string;
  metaDesc: string;
  emoji: string;
  category: string;
  intro: string;
  benefits: string[];
  faqs: { q: string; a: string }[];
  relatedLinks: { href: string; label: string }[];
}

const { title, seoTitle, metaDesc, emoji, category, intro, benefits, faqs, relatedLinks } = Astro.props;
---
<Layout title={seoTitle} description={metaDesc}>
  <Nav />
  <main class="pt-28 pb-0">

    <!-- Hero -->
    <section class="py-20 px-6 text-center border-b border-dark-border">
      <span class="text-5xl block mb-6">{emoji}</span>
      <p class="section-label mb-4">{category}</p>
      <h1 class="font-display text-4xl md:text-6xl font-300 max-w-3xl mx-auto leading-tight mb-6">
        <slot name="headline" />
      </h1>
      <span class="gold-line"></span>
      <p class="text-text-muted max-w-xl mx-auto text-sm font-300 leading-relaxed mb-10">{intro}</p>
      <a href="https://wa.me/821047944623" target="_blank" class="btn-gold mr-4">Book Now</a>
      <a href="/pricing" class="btn-outline">View Pricing</a>
    </section>

    <!-- Benefits -->
    <section class="py-20 px-6 lg:px-12 max-w-5xl mx-auto">
      <p class="section-label mb-4 text-center">What You Get</p>
      <h2 class="font-display text-3xl font-300 text-center mb-12">Why Choose <em class="text-gold">CHAHONG ROOM</em></h2>
      <div class="grid md:grid-cols-2 gap-5">
        {benefits.map((b, i) => (
          <div class="flex items-start gap-4 p-5 border border-dark-border hover:border-gold transition-colors group">
            <span class="font-mono text-xs text-gold mt-0.5 flex-shrink-0">0{i+1}</span>
            <p class="text-text-muted text-sm font-300 leading-relaxed">{b}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    {faqs.length > 0 && (
    <section class="py-20 px-6 lg:px-12 max-w-3xl mx-auto border-t border-dark-border">
      <p class="section-label mb-4 text-center">FAQ</p>
      <h2 class="font-display text-3xl font-300 text-center mb-12">Common <em class="text-gold">Questions</em></h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <details class="border border-dark-border group">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none">
              <span class="text-sm font-300 group-open:text-gold transition-colors">{faq.q}</span>
              <span class="text-gold text-lg group-open:rotate-45 transition-transform duration-200">+</span>
            </summary>
            <p class="px-6 pb-5 text-text-muted text-sm font-300 leading-relaxed border-t border-dark-border pt-4">{faq.a}</p>
          </details>
        ))}
      </div>
    </section>
    )}

    <!-- Related Services -->
    <section class="py-16 px-6 lg:px-12 max-w-5xl mx-auto border-t border-dark-border">
      <p class="section-label mb-6 text-center">Explore More</p>
      <div class="flex flex-wrap gap-3 justify-center">
        {relatedLinks.map(l => (
          <a href={l.href} class="btn-outline text-[0.68rem]">{l.label}</a>
        ))}
      </div>
    </section>

    <Contact />
    <Location />
  </main>
  <Footer />

  <a href="https://wa.me/821047944623" target="_blank"
    class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center shadow-xl hover:bg-[#1EBE5A] hover:scale-110 transition-all"
    aria-label="WhatsApp">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
</Layout>
