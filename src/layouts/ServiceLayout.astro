---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import Contact from '../components/Contact.astro';
import Location from '../components/Location.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  seoTitle: string;
  metaDesc: string;
  emoji: string;
  category: string;
  intro: string;
  benefits: string[];
  faqs: { q: string; a: string }[];
  relatedLinks: { href: string; label: string }[];
  heroImage?: string;
  pricing?: { service: string; price: string }[];
}

const { title, seoTitle, metaDesc, emoji, category, intro, benefits, faqs, relatedLinks, heroImage, pricing } = Astro.props;
---
<Layout title={seoTitle} description={metaDesc}>
  <Nav />
  <main class="pt-28 pb-0">

    <!-- Hero -->
    <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden">
      <div class="absolute inset-0">
        {heroImage ? (
          <img src={heroImage} alt={title} class="w-full h-full object-cover opacity-40" loading="eager" />
        ) : (
          <div class="w-full h-full" style="background: #DCCDBD;"></div>
        )}
        <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(247,244,239,0.7) 0%, rgba(247,244,239,0.9) 60%, #F7F4EF 100%);"></div>
      </div>
      <div class="relative z-10 text-center px-6 max-w-4xl mx-auto py-20">
        <span class="text-5xl block mb-6">{emoji}</span>
        <p class="mb-4 tracking-widest uppercase text-xs font-medium" style="color: #8D8076;">{category}</p>
        <h1 class="font-display text-4xl md:text-6xl leading-tight mb-6" style="color: #3A3838; font-weight: 300;">
          <slot name="headline" />
        </h1>
        <div class="mx-auto my-6" style="width: 60px; height: 1px; background: #A88F7B;"></div>
        <p class="max-w-xl mx-auto text-sm leading-relaxed mb-10" style="color: #8D8076;">{intro}</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://wa.me/821047944623" target="_blank"
            style="background: #A88F7B; color: white; font-weight: 600; padding: 14px 32px; border-radius: 6px; font-size: 14px; text-transform: uppercase; letter-spacing: 0.05em; display: inline-block;">
            📱 Book via WhatsApp
          </a>
          <a href="/pricing"
            style="border: 1.5px solid #A88F7B; color: #A88F7B; font-weight: 600; padding: 14px 32px; border-radius: 6px; font-size: 14px; text-transform: uppercase; letter-spacing: 0.05em; display: inline-block;">
            View Full Pricing
          </a>
        </div>
      </div>
    </section>

    <!-- Trust Badges -->
    <section class="py-8 px-6" style="border-top: 1px solid #DCCDBD; border-bottom: 1px solid #DCCDBD; background: #FFFFFF;">
      <div class="max-w-4xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        {[
          { num: '10+', label: 'Years Experience' },
          { num: '4.9★', label: 'Guest Rating' },
          { num: '100%', label: 'English Service' },
          { num: 'Free', label: 'Consultation' },
        ].map(b => (
          <div>
            <p class="font-display text-2xl" style="color: #A88F7B;">{b.num}</p>
            <p class="text-xs tracking-widest uppercase mt-1" style="color: #8D8076;">{b.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Benefits -->
    <section class="py-20 px-6 lg:px-12 max-w-5xl mx-auto">
      <p class="mb-4 text-center tracking-widest uppercase text-xs font-medium" style="color: #8D8076;">What You Get</p>
      <h2 class="font-display text-3xl text-center mb-12" style="color: #3A3838; font-weight: 300;">Why Choose <em style="color: #A88F7B;">CHAHONG ROOM</em></h2>
      <div class="grid md:grid-cols-2 gap-5">
        {benefits.map((b, i) => (
          <div class="flex items-start gap-4 p-5 transition-colors" style="border: 1px solid #DCCDBD;">
            <span class="font-mono text-xs mt-0.5 flex-shrink-0" style="color: #A88F7B;">0{i+1}</span>
            <p class="text-sm leading-relaxed" style="color: #8D8076;">{b}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-20 px-6 lg:px-12 max-w-3xl mx-auto" style="border-top: 1px solid #DCCDBD;">
      <p class="mb-4 text-center tracking-widest uppercase text-xs font-medium" style="color: #8D8076;">Transparent Pricing</p>
      <h2 class="font-display text-3xl text-center mb-4" style="color: #3A3838; font-weight: 300;">
        Service <em style="color: #A88F7B;">Pricing</em>
      </h2>
      <p class="text-xs text-center mb-10" style="color: #8D8076;">Prices in Korean Won (KRW). Final price may vary by hair length & condition.</p>
      <div style="border: 1px solid #DCCDBD; overflow: hidden; border-radius: 4px;">
        {(pricing ?? [
          { service: 'Basic Service', price: 'From ₩30,000' },
          { service: 'Standard Service', price: 'From ₩60,000' },
          { service: 'Premium Service', price: 'From ₩100,000' },
          { service: 'Full Package', price: 'From ₩150,000' },
        ]).map((item, i) => (
          <div class="flex items-center justify-between px-6 py-4" style={`background: ${i % 2 === 0 ? '#FFFFFF' : '#F7F4EF'}; border-bottom: 1px solid #DCCDBD;`}>
            <span class="text-sm" style="color: #3A3838;">{item.service}</span>
            <span class="text-sm font-mono font-500" style="color: #A88F7B;">{item.price}</span>
          </div>
        ))}
      </div>
      <div class="mt-6 p-5 text-center" style="border: 1px solid #DCCDBD;">
        <p class="text-xs mb-4" style="color: #8D8076;">Need an exact quote? Send us your reference photo via WhatsApp!</p>
        <a href="https://wa.me/821047944623" target="_blank"
          style="background: #A88F7B; color: white; font-weight: 600; padding: 10px 24px; border-radius: 6px; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; display: inline-block;">
          Get a Free Quote
        </a>
      </div>
    </section>

    <!-- Process -->
    <section class="py-20 px-6 lg:px-12 max-w-3xl mx-auto" style="border-top: 1px solid #DCCDBD;">
      <p class="mb-4 text-center tracking-widest uppercase text-xs font-medium" style="color: #8D8076;">How It Works</p>
      <h2 class="font-display text-3xl text-center mb-12" style="color: #3A3838; font-weight: 300;">Our <em style="color: #A88F7B;">Process</em></h2>
      <div class="space-y-8">
        {[
          { step: '01', title: 'Book via WhatsApp', desc: 'Send us a message with your desired service and reference photos. We\'ll confirm your appointment within a few hours.' },
          { step: '02', title: 'English Consultation', desc: 'Your stylist will discuss your hair goals, assess your hair condition, and recommend the best approach for you.' },
          { step: '03', title: 'Expert Treatment', desc: 'Relax while our skilled stylists work their magic using premium Korean products and techniques.' },
          { step: '04', title: 'Aftercare Guidance', desc: 'We\'ll walk you through aftercare tips in English so you can maintain your new look at home.' },
        ].map(s => (
          <div class="flex gap-6 items-start">
            <span class="font-mono text-3xl flex-shrink-0" style="color: #DCCDBD;">{s.step}</span>
            <div class="pl-6" style="border-left: 1px solid #DCCDBD;">
              <h3 class="font-display text-lg mb-2" style="color: #3A3838;">{s.title}</h3>
              <p class="text-sm leading-relaxed" style="color: #8D8076;">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    {faqs.length > 0 && (
    <section class="py-20 px-6 lg:px-12 max-w-3xl mx-auto" style="border-top: 1px solid #DCCDBD;">
      <p class="mb-4 text-center tracking-widest uppercase text-xs font-medium" style="color: #8D8076;">FAQ</p>
      <h2 class="font-display text-3xl text-center mb-12" style="color: #3A3838; font-weight: 300;">Common <em style="color: #A88F7B;">Questions</em></h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <details style="border: 1px solid #DCCDBD;">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none">
              <span class="text-sm" style="color: #3A3838;">{faq.q}</span>
              <span class="text-lg" style="color: #A88F7B;">+</span>
            </summary>
            <p class="px-6 pb-5 text-sm leading-relaxed pt-4" style="color: #8D8076; border-top: 1px solid #DCCDBD;">{faq.a}</p>
          </details>
        ))}
      </div>
    </section>
    )}

    <!-- Related Services -->
    <section class="py-16 px-6 lg:px-12 max-w-5xl mx-auto" style="border-top: 1px solid #DCCDBD;">
      <p class="mb-6 text-center tracking-widest uppercase text-xs font-medium" style="color: #8D8076;">Explore More Services</p>
      <div class="flex flex-wrap gap-3 justify-center">
        {relatedLinks.map(l => (
          <a href={l.href} style="border: 1.5px solid #A88F7B; color: #A88F7B; font-weight: 600; padding: 10px 20px; border-radius: 6px; font-size: 13px; text-transform: uppercase; letter-spacing: 0.05em; display: inline-block;">{l.label}</a>
        ))}
      </div>
    </section>

    <Contact />
    <Location />
  </main>
  <Footer />

  <a href="https://wa.me/821047944623" target="_blank"
    class="fixed bottom-6 right-6 z-50 w-14 h-14 rounded-full flex items-center justify-center shadow-xl transition-all"
    style="background: #25D366;"
    aria-label="WhatsApp">
    <svg width="26" height="26" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  </a>
</Layout>
